# OpenAI API
OPENAI_API_KEY=sk-...

# YouTube API
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_BUCKET_NAME=viral-shorts-videos
AWS_REGION=us-east-1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/viral_shorts_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin
ADMIN_PASSWORD=change-this-password-in-production

# Frontend
FRONTEND_URL=http://localhost:3000

# Environment
ENVIRONMENT=development
DEBUG=True

# FFmpeg (path to ffmpeg binary)
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# Processing
MAX_VIDEO_DURATION_MINUTES=120
MAX_FILE_SIZE_GB=5
TEMP_VIDEO_DIR=/tmp/viral_shorts

# Email
RESEND_API_KEY=re_...
ADMIN_EMAIL=admin@example.com

# Logging
LOG_LEVEL=INFO
